```gitignore
# ==========================================
# CiviCare / ASP.NET .gitignore
# ==========================================

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (Mono/Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# Uploaded Files / Media (Ignore citizen uploaded photos)
Uploads/
/Uploads/*
!/Uploads/placeholder.txt

# ==========================================
# 🛑 SECURITY: IGNORE CONFIGURATION FILES
# ==========================================
# Never upload database connection strings or API keys
Web.config
web.config
appsettings.json
secrets.config
*.env

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
